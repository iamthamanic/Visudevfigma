# Hybrid dev — copy to .env.local (optional; npm run dev:hybrid sets these automatically)
#
# VITE_SUPABASE_URL=http://127.0.0.1:54321
# VITE_SUPABASE_ANON_KEY=<from: supabase status --workdir src>
#
# Preview/Logs runners are started by npm run dev / dev:hybrid (no extra config needed).
# VITE_PREVIEW_RUNNER_URL=http://127.0.0.1:4000
# VITE_LOGS_RUNNER_URL=http://127.0.0.1:5000
