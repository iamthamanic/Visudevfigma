# Cloud Supabase — copy to .env.local (gitignored). Never commit real keys.
#
# Dashboard → Project Settings → API → anon public
# Rotate: create a new anon key in Dashboard, update .env.local, redeploy frontends.
#
VITE_SUPABASE_ANON_KEY=your-anon-jwt-from-supabase-dashboard
VISUDEV_CLOUD_ANON_KEY=your-anon-jwt-from-supabase-dashboard
