    "@types/pg": "^8.15.5",
    "@types/react": "^18.3.24",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react-swc": "^3.10.2",
    "concurrently": "^9.1.2",
    "eslint": "^9.19.0",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "jsdom": "^26.0.0",
    "prettier": "^3.5.3",
    "tsx": "^4.20.3",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.27.0",
    "vite": "^6.4.3",
    "vitest": "^3.2.6"
  },
  "overrides": {
    "esbuild": "^0.25.0",
    "vite": "^6.4.3"
  },
  "scripts": {
    "dev": "node scripts/dev-local.js",
    "dev:local": "node scripts/dev-local.js",
    "dev:local:no-runner": "node scripts/dev-local.js --no-runner",
    "dev:engine": "tsx watch local-engine/src/index.ts",
    "build:engine": "tsc -p local-engine/tsconfig.json",
    "start:engine": "node local-engine/dist/index.js",
    "dev:supabase": "node scripts/dev-hybrid.js",
    "dev:legacy": "npm run dev:supabase",
    "dev:hybrid": "npm run dev:supabase",
    "dev:hybrid:supabase": "node scripts/dev-hybrid.js",
    "dev:cloud": "node scripts/dev-auto.js",
    "ping:cloud": "node scripts/ping-cloud-supabase.js",
    "visudev-runner": "npm run dev:runner",
    "visudev-runner-status": "node scripts/visudev-runner-status.js",
    "visudev-logs-runner": "node scripts/run-logs-runner.js",
    "dev:kill-preview-port": "bash scripts/kill-preview-port.sh",
    "dev:runner": "node scripts/run-preview-runner.js",
    "dev:app": "vite",
    "seed:demo-user": "node scripts/seed-demo-user.js",
    "build": "vite build",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p local-engine/tsconfig.json",
    "typecheck:app": "tsc --noEmit -p tsconfig.json",
    "typecheck:engine": "tsc --noEmit -p local-engine/tsconfig.json",
    "test": "vitest",
    "test:run": "vitest run --passWithNoTests",
    "rules:check": "bash scripts/checks/project-rules.sh",
    "checks": "bash scripts/checks/run.sh",
    "supabase:checked": "bash scripts/supabase-checked.sh",
    "push": "bash scripts/push-checked.sh",
    "sync:shimwrapper": "bash scripts/sync-shimwrapper-repo.sh",
    "hooks:setup": "bash scripts/setup-hooks.sh",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:install": "playwright install chromium",
    "crawl:appflow": "node scripts/crawl-appflow/crawl.mjs",
    "migrate": "node scripts/migration/visudev-migrate.mjs",
    "e2e:maestro": "maestro test -e BASE_URL=http://127.0.0.1:3000 maestro/visudev-smoke.yaml",
    "e2e:maestro:preview": "bash scripts/maestro-test-preview.sh",
    "test:preview-runner": "cd preview-runner && npm run test:build",
    "postinstall": "node -e \"const fs=require('fs'),path=require('path');const cwd=process.cwd(),binDir=path.join(cwd,'node_modules','.bin');const links=[['supabase','supabase-checked.sh'],['push','push-checked.sh']];try{fs.mkdirSync(binDir,{recursive:true});for(const [name,script] of links){const bin=path.join(binDir,name),target=path.resolve(cwd,'scripts',script);try{fs.unlinkSync(bin);}catch(_){} fs.symlinkSync(target,bin);}}catch(e){}\""
  },
  "optionalDependencies": {
    "@rollup/rollup-darwin-arm64": "^4.62.2"
  }
}
